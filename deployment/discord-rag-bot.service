[Unit]
Description=Discord RAG Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=TU_USUARIO
Group=TU_USUARIO
WorkingDirectory=/ruta/completa/a/discord-rag-bot
ExecStart=/ruta/completa/a/discord-rag-bot/venv/bin/python /ruta/completa/a/discord-rag-bot/bot.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
